---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;

const socials = [
  {
    label: 'GitHub',
    href: 'https://github.com/axeimk',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.868-.013-1.703-2.782.604-3.369-1.342-3.369-1.342-.454-1.154-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/></svg>`,
  },
  {
    label: 'X (Twitter)',
    href: 'https://x.com/axeimk',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.253 5.622 5.912-5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>`,
  },
  {
    label: 'RSS',
    href: `${base}rss.xml`,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/></svg>`,
  },
];
---

<BaseLayout title="About | imk blog" description="このブログについて">
  <article class="max-w-3xl mx-auto">
    <header class="mb-10">
      <h1
        class="font-serif text-4xl font-bold mb-3"
        style="font-family: 'Noto Serif JP', serif;"
      >
        About
      </h1>
      <div class="w-12 h-[2px]" style="background-color: var(--color-accent);"></div>
    </header>

    <!-- プロフィールカード -->
    <div
      class="flex flex-col sm:flex-row items-center sm:items-start gap-6 rounded-xl p-6 mb-10 border"
      style="background-color: var(--color-bg-surface); border-color: var(--color-border);"
    >
      <!-- アバター -->
      <img
        src="https://github.com/axeimk.png"
        alt="axeimk"
        width="96"
        height="96"
        class="rounded-full shrink-0 ring-2"
        style="ring-color: var(--color-border);"
      />

      <!-- テキスト + ソーシャルリンク -->
      <div class="flex-1 text-center sm:text-left">
        <p class="font-semibold text-lg mb-1">axeimk</p>
        <p class="text-sm mb-4" style="color: var(--color-text-muted);">
          Webを中心にいろいろ書きます。
        </p>

        <!-- ソーシャルアイコン -->
        <div class="flex items-center gap-3 justify-center sm:justify-start">
          {
            socials.map(({ label, href, icon }) => (
              <a
                href={href}
                target={href.startsWith('http') ? '_blank' : undefined}
                rel={href.startsWith('http') ? 'noopener noreferrer' : undefined}
                aria-label={label}
                class="p-2 rounded-full transition-all duration-200 hover:-translate-y-0.5 hover:text-(--color-accent)"
                style="color: var(--color-text-muted); background-color: var(--color-bg);"
                title={label}
              >
                <Fragment set:html={icon} />
              </a>
            ))
          }
        </div>
      </div>
    </div>

    <!-- ブログ説明 -->
    <div class="prose dark:prose-invert max-w-none prose-a:text-(--color-accent)">
      <p>このブログは日々の技術的な学びやメモ、考えをまとめる場所です。</p>
    </div>
  </article>
</BaseLayout>
