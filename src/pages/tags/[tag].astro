---
import { getCollection } from 'astro:content';
import type { InferGetStaticPropsType } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getExcerpt } from '../../utils/excerpt';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const tags = [...new Set(posts.flatMap((post) => post.data.tags))];
  return tags.map((tag) => ({
    params: { tag },
    props: {
      posts: posts
        .filter((post) => post.data.tags.includes(tag))
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

type Props = InferGetStaticPropsType<typeof getStaticPaths>;
const { tag } = Astro.params;
const { posts }: Props = Astro.props;
---

<BaseLayout
  title={`#${tag} | 供養ログ`}
  description={`タグ「${tag}」の記事一覧`}
>
  <header class="mb-10">
    <h1
      class="font-serif text-3xl font-bold mb-3"
      style="font-family: 'Noto Serif JP', serif;"
    >
      <span style="color: var(--color-text-muted); font-weight: 400; font-size: 0.75em;">#</span>{tag}
      <span class="text-base font-normal ml-2" style="color: var(--color-text-muted);">{posts.length}件</span>
    </h1>
    <div
      class="w-12 h-[2px]"
      style="background-color: var(--color-accent); animation: accent-line-grow 0.6s ease 0.3s both;"
    ></div>
  </header>
  <div class="grid grid-cols-1 gap-5">
    {
      posts.map((post, i) => (
        <div style={`animation: fade-in-up 0.4s ease both; animation-delay: ${i * 0.06}s;`}>
          <PostCard
            id={post.id}
            title={post.data.title}
            excerpt={getExcerpt(post.body ?? '')}
            pubDate={post.data.pubDate}
            tags={post.data.tags}
          />
        </div>
      ))
    }
  </div>
</BaseLayout>
