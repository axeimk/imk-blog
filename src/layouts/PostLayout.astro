---
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import TableOfContents from '../components/TableOfContents.astro';
import type { MarkdownHeading } from 'astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags: string[];
  heroImage?: string;
  headings?: MarkdownHeading[];
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  tags,
  heroImage,
  headings = [],
} = Astro.props;
const base = import.meta.env.BASE_URL;
---

<BaseLayout title={title} description={description} image={heroImage}>
  <article class="max-w-3xl mx-auto">
    {
      heroImage && (
        <div class="rounded-xl overflow-hidden mb-10">
          <img src={heroImage} alt={title} class="w-full object-cover" />
        </div>
      )
    }
    <header class="mb-10">
      <h1
        class="font-serif text-4xl md:text-5xl font-bold leading-tight mb-5"
        style="font-family: 'Noto Serif JP', serif;"
      >
        {title}
      </h1>
      <div
        class="flex flex-wrap items-center gap-3 text-sm text-(--color-text-muted) mb-6"
      >
        <FormattedDate date={pubDate} />
        {
          updatedDate && (
            <span>
              (更新: <FormattedDate date={updatedDate} />)
            </span>
          )
        }
        {
          tags.length > 0 && (
            <div class="flex gap-1.5 flex-wrap">
              {tags.map((tag) => (
                <a
                  href={`${base}tags/${tag}`}
                  class="px-2 py-0.5 text-xs font-medium border-l-2 transition-colors hover:opacity-80"
                  style="background-color: var(--color-accent-soft); color: var(--color-accent); border-color: var(--color-accent);"
                >
                  #{tag}
                </a>
              ))}
            </div>
          )
        }
      </div>
      <div
        class="w-16 h-[2px]"
        style="background-color: var(--color-accent);"
      ></div>
    </header>

    <div class="prose dark:prose-invert max-w-none">
      <TableOfContents headings={headings} />
      <slot />
    </div>
  </article>
</BaseLayout>

<script>
  const setupCopyButtons = () => {
    const blocks = document.querySelectorAll<HTMLPreElement>('.prose pre');
    blocks.forEach((pre) => {
      if (pre.querySelector('.copy-button')) return;
      const button = document.createElement('button');
      button.type = 'button';
      button.className = 'copy-button';
      button.textContent = 'Copy';
      button.setAttribute('aria-label', 'コードをコピー');
      button.addEventListener('click', async () => {
        const code = pre.querySelector('code')?.innerText ?? pre.innerText;
        try {
          await navigator.clipboard.writeText(code);
          button.textContent = 'Copied';
          button.dataset.copied = 'true';
          setTimeout(() => {
            button.textContent = 'Copy';
            delete button.dataset.copied;
          }, 1500);
        } catch {
          button.textContent = 'Failed';
          setTimeout(() => (button.textContent = 'Copy'), 1500);
        }
      });
      pre.appendChild(button);
    });
  };
  setupCopyButtons();
</script>
