---
const base = import.meta.env.BASE_URL;
---

<footer class="border-t border-(--color-border) mt-16">
  <div
    class="max-w-2xl mx-auto px-4 py-6 flex items-center justify-between text-sm text-(--color-text-muted)"
  >
    <span>&copy; {new Date().getFullYear()} imk blog</span>
    <a
      href={`${base}rss.xml`}
      class="hover:text-(--color-accent) transition-colors"
    >
      RSS
    </a>
  </div>
</footer>
